<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:name="com.example.plantasya.HomeFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnCamera"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="@drawable/round_button"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="104dp"
        android:padding="18dp"
        android:scaleType="centerInside"
        android:src="@drawable/camera"
        app:backgroundTint="@color/plant_green"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/plant_green"
        app:strokeWidth="1dp" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:background="@color/bottom_nav_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnNavHome"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="15dp"
            android:layout_marginEnd="15dp"
            android:background="@drawable/round_button"
            android:src="@drawable/home" />

        <ImageButton
            android:id="@+id/btnNavDictionary"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="15dp"
            android:layout_marginEnd="15dp"
            android:background="@drawable/round_button_white"
            android:src="@drawable/dictionary" />

        <ImageButton
            android:id="@+id/btnNavHistory"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="15dp"
            android:layout_marginEnd="15dp"
            android:background="@drawable/round_button_white"
            android:src="@drawable/history"/>

        <ImageButton
            android:id="@+id/btnNavProfile"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="15dp"
            android:layout_marginEnd="15dp"
            android:background="@drawable/round_button_white"
            android:src="@drawable/profile"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
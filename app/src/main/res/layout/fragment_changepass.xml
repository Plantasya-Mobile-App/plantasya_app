<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ImageView
        android:id="@+id/ivWatermark"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:alpha="0.15"
        android:src="@drawable/faded"
        android:contentDescription="Tree Watermark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:layout_marginStart="40dp"
        android:fontFamily="serif"
        android:text="Change Username\n&amp; Password"
        android:textColor="@color/black"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/llFields"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <EditText
            android:id="@+id/etCurrentUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="Current Username"
            android:inputType="text"
            android:paddingBottom="8dp"
            android:textColor="@color/black"
            android:textColorHint="#A9A9A9" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="@color/black" />

        <EditText
            android:id="@+id/etNewUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@null"
            android:hint="New Username"
            android:inputType="text"
            android:paddingBottom="8dp"
            android:textColor="@color/black"
            android:textColorHint="#A9A9A9" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="@color/black" />

        <EditText
            android:id="@+id/etCurrentPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@null"
            android:hint="Current Password"
            android:inputType="textPassword"
            android:paddingBottom="8dp"
            android:textColor="@color/black"
            android:textColorHint="#A9A9A9" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="@color/black" />

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@null"
            android:hint="New Password"
            android:inputType="textPassword"
            android:paddingBottom="8dp"
            android:textColor="@color/black"
            android:textColorHint="#A9A9A9" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="@color/black" />

    </LinearLayout>

    <Button
        android:id="@+id/btnSaveChanges"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:backgroundTint="@color/plant_green"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:text="Save Changes"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llFields" />

</androidx.constraintlayout.widget.ConstraintLayout>
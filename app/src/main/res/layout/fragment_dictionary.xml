<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ImageView
        android:id="@+id/ivWatermark"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:alpha="0.15"
        android:src="@drawable/faded"
        android:contentDescription="Tree Watermark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDictionaryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:fontFamily="serif"
        android:text="SEARCH PLANT"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/llSearch"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="40dp"
        android:background="@drawable/search_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDictionaryTitle">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="Search Icon"
            app:tint="@color/black" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/llAlphabetSidebar"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bottom_nav_shape"
        android:backgroundTint="@color/bottom_nav_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="A" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="B" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="C" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="D" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="E" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="F" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="G" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="H" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="I" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="J" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="K" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="L" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="M" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="N" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="O" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="P" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="Q" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="R" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="S" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="T" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="U" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="V" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="W" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="X" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="Y" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="serif" android:text="Z" android:textColor="@color/black" android:textSize="11sp" android:textStyle="italic" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>